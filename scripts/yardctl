#!/usr/bin/env bash
# yardctl — operate the syslog-yard suite on a Linux host.
#
#   yardctl prereqs    install a container runtime + compose (dnf or apt)
#   yardctl up         build images and start the suite
#   yardctl down       stop the suite (volumes are kept)
#   yardctl restart    restart all suite services
#   yardctl status     container status + UI health checks
#   yardctl logs [svc] follow logs (all services or one)
#   yardctl firewall   open the yard's ports (firewalld or ufw; needs sudo)
#   yardctl firewall-remove   close them again
#   yardctl service-install   start the suite at boot (systemd unit)
#   yardctl service-remove    stop starting at boot (suite keeps running)
#   yardctl smoke      send a test message through valve -> bucket
#   yardctl reset-admin   set a fresh random syslog-bucket admin password
#
# UI ports: 8080 (hose) 8081 (valve) 8082 (bucket); syslog entry: 6514 udp+tcp.
set -euo pipefail

YARD_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMPOSE_FILE="$YARD_DIR/deploy/compose.yaml"
UI_PORTS=(8080 8081 8082)
SYSLOG_PORT=6514

info() { printf '\e[1;34m[yardctl]\e[0m %s\n' "$*"; }
die()  { printf '\e[1;31m[yardctl]\e[0m %s\n' "$*" >&2; exit 1; }

compose() {
    if command -v docker >/dev/null && docker compose version >/dev/null 2>&1; then
        docker compose -f "$COMPOSE_FILE" "$@"
    elif command -v podman >/dev/null && podman compose version >/dev/null 2>&1; then
        podman compose -f "$COMPOSE_FILE" "$@"
    elif command -v podman-compose >/dev/null; then
        podman-compose -f "$COMPOSE_FILE" "$@"
    else
        die "no compose runtime found — run: yardctl prereqs"
    fi
}

prereqs() {
    if command -v docker >/dev/null || command -v podman >/dev/null; then
        info "container runtime already present: $(command -v docker || command -v podman)"
    elif command -v dnf >/dev/null; then
        info "installing podman + podman-compose (dnf)"
        sudo dnf install -y podman podman-compose
    elif command -v apt-get >/dev/null; then
        info "installing docker + compose plugin (apt)"
        sudo apt-get update
        sudo apt-get install -y docker.io docker-compose-v2
        sudo systemctl enable --now docker
        info "add yourself to the docker group (or use sudo): sudo usermod -aG docker \$USER"
    else
        die "unsupported distro: install docker or podman manually"
    fi
    for tool in curl logger; do
        command -v "$tool" >/dev/null || info "note: '$tool' not found — needed for status/smoke"
    done
    info "prereqs OK"
}

firewall() {
    local action="$1" # add | remove
    if systemctl is-active --quiet firewalld 2>/dev/null; then
        local op="--add-port" && [ "$action" = remove ] && op="--remove-port"
        info "configuring firewalld ($action)"
        for p in "${UI_PORTS[@]}"; do sudo firewall-cmd --permanent "$op=$p/tcp"; done
        sudo firewall-cmd --permanent "$op=$SYSLOG_PORT/tcp"
        sudo firewall-cmd --permanent "$op=$SYSLOG_PORT/udp"
        sudo firewall-cmd --reload
        info "firewalld updated. If host->container UDP still fails, trust the"
        info "compose bridge interface:"
        info '  BR=br-$(docker network inspect syslog-yard_yardnet -f "{{.Id}}" | cut -c1-12)'
        info '  sudo firewall-cmd --permanent --zone=trusted --add-interface=$BR'
        info '  sudo firewall-cmd --reload'
    elif command -v ufw >/dev/null; then
        local cmd="allow" && [ "$action" = remove ] && cmd="delete allow"
        info "configuring ufw ($action)"
        for p in "${UI_PORTS[@]}"; do sudo ufw $cmd "$p/tcp"; done
        sudo ufw $cmd "$SYSLOG_PORT/tcp"
        sudo ufw $cmd "$SYSLOG_PORT/udp"
    else
        info "no firewalld/ufw detected — open these yourself if needed:"
        info "  tcp: ${UI_PORTS[*]} $SYSLOG_PORT   udp: $SYSLOG_PORT"
    fi
}

SERVICE=syslog-yard.service

# service_install makes the suite survive reboots: a oneshot systemd unit
# runs `compose up -d` at boot. Docker (and podman run as root) get a
# system unit; rootless podman gets a user unit plus lingering, since
# without a daemon its restart policies don't outlive a reboot.
service_install() {
    command -v systemctl >/dev/null || die "systemd not found"
    local docker_dep="" tmp
    if command -v docker >/dev/null && docker compose version >/dev/null 2>&1; then
        docker_dep=$'After=docker.service\nRequires=docker.service'
    fi
    tmp=$(mktemp)
    cat >"$tmp" <<EOF
[Unit]
Description=syslog-yard suite (hose / valve / bucket)
Wants=network-online.target
After=network-online.target
$docker_dep

[Service]
Type=oneshot
RemainAfterExit=yes
TimeoutStartSec=600
ExecStart=$YARD_DIR/scripts/yardctl service-up
ExecStop=$YARD_DIR/scripts/yardctl down

[Install]
WantedBy=multi-user.target
EOF
    if [ -n "$docker_dep" ] || [ "$(id -u)" -eq 0 ]; then
        info "installing system unit /etc/systemd/system/$SERVICE"
        sudo install -m 0644 "$tmp" "/etc/systemd/system/$SERVICE"
        sudo systemctl daemon-reload
        sudo systemctl enable --now "$SERVICE"
        if [ -z "$docker_dep" ] && [ "$(id -u)" -eq 0 ]; then
            info "note: the unit runs podman as root — keep doing manual ops as"
            info "root too, or you'd be driving a second rootless instance"
        fi
    else
        info "installing user unit (~/.config/systemd/user/$SERVICE)"
        sed -i 's/^WantedBy=.*/WantedBy=default.target/' "$tmp"
        mkdir -p "$HOME/.config/systemd/user"
        install -m 0644 "$tmp" "$HOME/.config/systemd/user/$SERVICE"
        systemctl --user daemon-reload
        systemctl --user enable --now "$SERVICE"
        # Lingering lets the user unit start at boot, before any login.
        loginctl enable-linger "$USER" 2>/dev/null \
            || sudo loginctl enable-linger "$USER"
    fi
    rm -f "$tmp"
    info "service installed — the suite now starts at boot"
}

service_remove() {
    if [ -f "/etc/systemd/system/$SERVICE" ]; then
        sudo systemctl disable "$SERVICE" || true
        sudo rm "/etc/systemd/system/$SERVICE"
        sudo systemctl daemon-reload
    elif [ -f "$HOME/.config/systemd/user/$SERVICE" ]; then
        systemctl --user disable "$SERVICE" || true
        rm "$HOME/.config/systemd/user/$SERVICE"
        systemctl --user daemon-reload
    else
        info "no $SERVICE installed"
        return
    fi
    info "boot service removed (suite untouched; 'yardctl down' stops it)"
}

status() {
    compose ps
    echo
    for p in "${UI_PORTS[@]}"; do
        if curl -fsS -m 2 -o /dev/null "http://localhost:$p/"; then
            info "UI :$p up"
        else
            info "UI :$p NOT responding"
        fi
    done
}

# bucket_stored reports whether a message containing needle has landed in
# the bucket's store. It queries Postgres directly rather than the REST API:
# /api/entries needs a session (auth required), and the datastore is the
# most direct "did it actually get stored" check anyway. Needs the suite up.
bucket_stored() {
    local needle="$1" n
    n=$(compose exec -T bucket-db psql -U syslog_bucket -tAc \
        "select count(*) from entries where msg like '%${needle}%'" 2>/dev/null | tr -d '[:space:]')
    [ "${n:-0}" -gt 0 ] 2>/dev/null
}

smoke() {
    # user.err: severe enough that the demo flow's severity filter forwards
    # it to the bucket instead of caching it as noise. Probe both transports:
    # VM-based runtimes (Rancher/Docker Desktop, Colima) forward TCP but not
    # UDP, so one missing transport is a warning, not a failure.
    local ts ok=""
    ts=$(date +%s)
    info "sending test messages to localhost:$SYSLOG_PORT (udp + tcp)"
    logger -n 127.0.0.1 -P "$SYSLOG_PORT" -d -p user.err --rfc3164 -t yard-udp "yardctl smoke udp $ts" || true
    logger -n 127.0.0.1 -P "$SYSLOG_PORT" -T -p user.err --rfc3164 -t yard-tcp "yardctl smoke tcp $ts" || true
    sleep 2
    for proto in udp tcp; do
        if bucket_stored "smoke $proto $ts"; then
            info "smoke $proto OK — reached syslog-bucket"
            ok=1
        else
            info "smoke $proto: message did not arrive (needs an applied, enabled External IN block on the valve; UDP cannot cross VM-based runtimes' port forwarding)"
        fi
    done
    [ -n "$ok" ] || die "smoke FAILED — nothing reached syslog-bucket (valve flow applied? firewall? see yardctl firewall)"
}

reset_admin() {
    # Generate a fresh random admin password (the bucket prints it). Useful
    # on a forgotten password or to rotate the generated one. Runs inside
    # the live container so it reuses its database connection.
    info "resetting the syslog-bucket admin password"
    compose exec -T syslog-bucket syslog-bucket reset-admin \
        || die "could not reach the syslog-bucket container — is the suite up? (yardctl up)"
    info "other admin sessions were signed out; sign in at http://localhost:8082"
}

case "${1:-}" in
    prereqs)          prereqs ;;
    up|start)         compose up -d --build && status ;;
    down|stop)        compose down ;;
    restart)          compose restart && status ;;
    status)           status ;;
    logs)             shift; compose logs -f "$@" ;;
    firewall)         firewall add ;;
    firewall-remove)  firewall remove ;;
    service-install)  service_install ;;
    service-remove)   service_remove ;;
    service-up)       compose up -d ;; # systemd ExecStart hook (no build/curl)
    smoke)            smoke ;;
    reset-admin)      reset_admin ;;
    *)                grep '^#   yardctl' "$0" | sed 's/^# *//'; exit 1 ;;
esac
